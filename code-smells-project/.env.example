# Chave secreta do Flask (gere com: python -c "import secrets; print(secrets.token_hex(32))")
# OBRIGATÓRIO mudar em produção — a chave hardcoded anterior deve ser considerada VAZADA.
SECRET_KEY=dev-only-change-me

# Ativa modo debug (0=desligado, 1=ligado; NUNCA 1 em produção)
FLASK_DEBUG=0

# Host e porta do servidor
HOST=127.0.0.1
PORT=5000

# Caminho do arquivo SQLite
DATABASE_PATH=loja.db

# Origens permitidas para CORS (separe com vírgula; * libera tudo — restrinja em produção)
CORS_ORIGINS=*

# Token de acesso para endpoints administrativos:
#   GET  /relatorios/vendas
#   POST /admin/reset-db
#   POST /admin/query  (marcado para remoção — ver Security Contract Changes)
# Enviar como header:  X-Admin-Token: <valor>
# Deixar vazio = 403 para todos (comportamento seguro por default)
ADMIN_TOKEN=
