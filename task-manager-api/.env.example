# Segurança — ROTACIONE os valores antes de usar em produção
SECRET_KEY=change-me-in-production
ADMIN_TOKEN=change-me-in-production

# Servidor
FLASK_DEBUG=0
HOST=127.0.0.1
PORT=5000

# Banco de dados
DATABASE_URI=sqlite:///tasks.db

# CORS (use '*' apenas em dev; em produção liste origens separadas por vírgula)
CORS_ORIGINS=*

# Email (SMTP) — deixe em branco para desabilitar envio
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
