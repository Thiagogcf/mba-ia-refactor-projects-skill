# Porta do servidor (default: 3000)
PORT=3000

# Chave do gateway de pagamento (OBRIGATÓRIA em produção)
PAYMENT_GATEWAY_KEY=

# Token de acesso para endpoints administrativos (OBRIGATÓRIO em produção)
# Sem esta variável definida, GET /api/admin/financial-report e DELETE /api/users/:id retornam 403
ADMIN_TOKEN=
